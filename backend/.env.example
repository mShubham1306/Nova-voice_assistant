# NOVA Voice Assistant - Environment Configuration
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=nova-secret-key-change-me
DEBUG=True
HOST=0.0.0.0
PORT=5000

# Google Gemini AI (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=

# Voice Settings
VOICE_RATE=180
VOICE_GENDER=female
LISTEN_TIMEOUT=5
PHRASE_TIME_LIMIT=8
LANGUAGE=en-in
